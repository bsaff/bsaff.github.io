---
import BaseLayout from "../layouts/Base.astro";
---

<BaseLayout title="Music">
  <section>
    <div class="flex flex-col justify-center gap-8 w-full max-w-[900px] mx-auto pt-12 sm:pt-16">
      <div class="flex flex-col justify-start max-w-[400px] w-full mx-auto">
        <div class="text-lg text-gray-600 mb-3 mt-0">Kintsugi (2015–Present)</div>
        <iframe
          style="border: 0; width: 100%; height: 120px;"
          src="https://bandcamp.com/EmbeddedPlayer/track=188520554/size=large/bgcol=ffffff/linkcol=0687f5/tracklist=false/artwork=small/transparent=true/"
          seamless></iframe>
      </div>
      <div class="flex flex-col justify-start max-w-[400px] w-full mx-auto">
        <div class="text-lg text-gray-600 mb-3 mt-0">Soul Eater (2015–2016)</div>
        <iframe
          style="border: 0; width: 100%; height: 120px;"
          src="https://bandcamp.com/EmbeddedPlayer/album=560240247/size=large/bgcol=ffffff/linkcol=0687f5/tracklist=false/artwork=small/transparent=true/"
          seamless></iframe>
      </div>
      <div class="flex flex-col justify-start max-w-[400px] w-full mx-auto">
        <div class="text-lg text-gray-600 mb-3 mt-0">Maris Lane (2011–2015)</div>
        <iframe
          style="border: 0; width: 100%; height: 120px;"
          src="https://bandcamp.com/EmbeddedPlayer/album=83839495/size=large/bgcol=ffffff/linkcol=0687f5/tracklist=false/artwork=small/track=2430430375/transparent=true/"
          seamless></iframe>
      </div>

    </div>
  </section>
</BaseLayout>
